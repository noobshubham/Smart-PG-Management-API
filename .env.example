# --- Application ---
APP_ENV=development
APP_DEBUG=true

# --- Database ---
# Dev (SQLite): sqlite:///./smart_pg.db
# Prod (Postgres): postgresql+psycopg2://user:pass@host:5432/smart_pg
DATABASE_URL=sqlite:///./smart_pg.db

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=

# --- WhatsApp (Meta or Twilio) ---
WHATSAPP_PROVIDER=meta
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Background Workers ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
